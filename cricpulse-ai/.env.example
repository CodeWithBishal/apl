# =========================================================================
# CricPulse AI — Environment Variables
# Copy this file to .env and fill in your values
# =========================================================================

# -------------------------------------------------------------------------
# MODE CONTROL
# -------------------------------------------------------------------------
# true  → read from src/fixtures/match.json (hackathon demo, no API keys needed)
# false → fetch from proxy server / Cloud Functions (live data)
REACT_APP_FIXTURE_MODE=false

# Match ID from Cricbuzz (visible in the URL of any live scorecard)
# e.g. cricbuzz.com/live-cricket-scorecard/151976/usa-vs-ire-...
REACT_APP_MATCH_ID=151976

# -------------------------------------------------------------------------
# PROXY / CLOUD FUNCTIONS BASE URL
# -------------------------------------------------------------------------
# LOCAL DEV: Run `npm run server` first, then this is your proxy:
REACT_APP_CLOUD_FUNCTIONS_BASE_URL=http://localhost:4000
# GCP PRODUCTION (after `firebase deploy --only functions`):
# REACT_APP_CLOUD_FUNCTIONS_BASE_URL=https://REGION-PROJECT_ID.cloudfunctions.net

# -------------------------------------------------------------------------
# GEMINI AI (Client-side direct — used as fallback when proxy is down)
# Get key at: https://aistudio.google.com/app/apikey
# -------------------------------------------------------------------------
REACT_APP_GEMINI_API_KEY=YOUR_GEMINI_KEY_HERE

# -------------------------------------------------------------------------
# CLIENT-SIDE SENTIMENT + LANGUAGE SAFETY (optional direct fallback)
# Restrict these API keys by HTTP referrer in Google Cloud Console.
# Natural Language API: https://console.cloud.google.com/apis/library/language.googleapis.com
# Perspective API: https://developers.perspectiveapi.com/
# -------------------------------------------------------------------------
REACT_APP_GCP_NL_API_KEY=
REACT_APP_PERSPECTIVE_API_KEY=

# -------------------------------------------------------------------------
# FIREBASE / FIRESTORE (for real-time chat + leaderboard)
# Get these from Firebase Console → Project Settings → Your apps
# Leave blank to use in-memory state (works fine for demos)
# -------------------------------------------------------------------------
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=

# =========================================================================
# SERVER-SIDE ONLY — used by server/index.js and cloud-functions/
# These MUST NOT be prefixed with REACT_APP_ (never exposed to client)
# =========================================================================

# RapidAPI key for Cricbuzz API
# Get at: https://rapidapi.com/cricbuzz/api/cricbuzz-cricket
RAPIDAPI_KEY=YOUR_RAPIDAPI_KEY_HERE

# GCP Natural Language API (optional — proxy uses rule-based fallback if not set)
# Enable at: https://console.cloud.google.com/apis/library/language.googleapis.com
GCP_NL_API_KEY=

# Proxy server port (default: 4000)
PROXY_PORT=4000
